<Window x:Class="InstaBuild.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="InstaBuild"
        Width="1200" Height="720"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource BgBrush}">
    <Window.Resources>
        <!-- theme -->
        <SolidColorBrush x:Key="BgBrush"       Color="#0F1222"/>
        <SolidColorBrush x:Key="SidebarBrush"  Color="#161A2E"/>
        <SolidColorBrush x:Key="PanelBrush"    Color="#1D223B"/>
        <SolidColorBrush x:Key="TextBrush"     Color="#E8ECF8"/>
        <SolidColorBrush x:Key="SubTextBrush"  Color="#9AA4C7"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#4CC9F0"/>
        <SolidColorBrush x:Key="DangerBrush"   Color="#FF6B6B"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="#273055"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor"  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="BorderBrush"  Value="#2F3A66"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
        </Style>
        <Style x:Key="SidebarItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" CornerRadius="8" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="6,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2B355E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#233058"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Title bar -->
        <Grid Background="#0C1020" Height="38" VerticalAlignment="Top"
              MouseDown="TitleBar_MouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Version: 0.9291" Foreground="{DynamicResource SubTextBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="MinBtn"  Style="{StaticResource TitleBtn}" Click="MinBtn_Click"  ToolTip="Minimize">
                    <Path Data="M0,0 L10,0" Stroke="{DynamicResource TextBrush}" StrokeThickness="2" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
                <Button x:Name="MaxBtn"  Style="{StaticResource TitleBtn}" Click="MaxBtn_Click"  ToolTip="Maximize">
                    <Rectangle Stroke="{DynamicResource TextBrush}" StrokeThickness="2" Width="12" Height="12"/>
                </Button>
                <Button x:Name="CloseBtn" Style="{StaticResource TitleBtn}" Click="CloseBtn_Click" ToolTip="Close">
                    <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="{DynamicResource TextBrush}" StrokeThickness="2" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid Margin="0,38,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
                <DockPanel>
                    <TextBlock Text="InstaBuild"
                               FontWeight="Bold" FontSize="20"
                               Margin="16,16,16,8"/>
                    <ListBox x:Name="NavList"
                             DockPanel.Dock="Bottom"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextBrush}"
                             SelectionChanged="NavList_SelectionChanged"
                             ItemContainerStyle="{StaticResource SidebarItem}">
                        <ListBoxItem>Dashboard</ListBoxItem>
                        <ListBoxItem IsSelected="True">Macros</ListBoxItem>
                        <ListBoxItem>Analytics</ListBoxItem>
                        <ListBoxItem>Network</ListBoxItem>
                        <ListBoxItem>Settings</ListBoxItem>
                        <ListBoxItem>Info</ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Pages -->
            <Grid Grid.Column="1" Margin="16">
                <!-- Macros -->
                <Grid x:Name="MacrosView" Visibility="Visible">
                    <UniformGrid Columns="2" Rows="3" Margin="0,8,0,0">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Primary Macro Keys" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ComboBox x:Name="Combo1" Margin="0,0,0,8"/>
                                <ComboBox x:Name="Combo2" Margin="0,0,0,8"/>
                                <ComboBox x:Name="Combo3" Margin="0,0,0,8"/>
                                <ComboBox x:Name="Combo4"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock x:Name="StatusText" Text="Status: Deactivated"
                                           Foreground="{DynamicResource DangerBrush}"
                                           FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button x:Name="StartBtn" Content="Start" Width="120" Height="40" Click="StartBtn_Click"/>
                                    <Button x:Name="StopBtn"  Content="Stop"  Width="120" Height="40" Click="StopBtn_Click" IsEnabled="False"/>
                                </StackPanel>
                                <TextBlock Margin="0,16,0,0" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap">
                                    Disclaimer: using automated input in some games may violate their Terms of Service and can be detected by anti-cheat software. Use at your own risk.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Live CPU / RAM" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <UniformGrid Columns="2" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="CPU" Foreground="{DynamicResource SubTextBrush}"/>
                                        <TextBlock x:Name="CpuText" Text="0%" FontSize="28" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="RAM" Foreground="{DynamicResource SubTextBrush}"/>
                                        <TextBlock x:Name="RamText" Text="0%" FontSize="28" FontWeight="Bold"/>
                                    </StackPanel>
                                </UniformGrid>
                                <TextBlock Text="(updates every second)" Foreground="{DynamicResource SubTextBrush}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>

                <!-- Dashboard -->
                <Grid x:Name="DashboardView" Visibility="Collapsed">
                    <UniformGrid Columns="3">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="CPU Usage" Foreground="{DynamicResource SubTextBrush}"/>
                                <TextBlock x:Name="CpuTextDash" Text="0%" FontSize="36" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="RAM Usage" Foreground="{DynamicResource SubTextBrush}"/>
                                <TextBlock x:Name="RamTextDash" Text="0%" FontSize="36" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Status" Foreground="{DynamicResource SubTextBrush}"/>
                                <TextBlock x:Name="StatusTextDash" Text="Deactivated" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>

                <!-- Analytics -->
                <Grid x:Name="AnalyticsView" Visibility="Collapsed">
                    <Border Style="{StaticResource Card}">
                        <TextBlock Text="Analytics (placeholder – add charts later)" />
                    </Border>
                </Grid>

                <!-- Network -->
                <Grid x:Name="NetworkView" Visibility="Collapsed">
                    <Border Style="{StaticResource Card}">
                        <TextBlock Text="Network (placeholder – add speed/ping later)" />
                    </Border>
                </Grid>

                <!-- Settings -->
                <Grid x:Name="SettingsView" Visibility="Collapsed">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Theme Colors" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <UniformGrid Columns="2" Rows="3" Margin="0,8,0,0">
                                <Button Content="Blue"   Click="ThemeBlue_Click"/>
                                <Button Content="Red"    Click="ThemeRed_Click"/>
                                <Button Content="Green"  Click="ThemeGreen_Click"/>
                                <Button Content="Purple" Click="ThemePurple_Click"/>
                                <Button Content="Default" Click="ThemeDefault_Click"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Info -->
                <Grid x:Name="InfoView" Visibility="Collapsed">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Build Info" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="Name: InstaBuild" Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="Version: 0.9291"   Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text=".NET: 8.0 (Windows)" Foreground="{DynamicResource SubTextBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
