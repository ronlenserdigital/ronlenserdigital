<Application x:Class="InstaBuild.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style TargetType="Window">
            <Setter Property="Background" Value="#111318"/>
            <Setter Property="Foreground" Value="#E9ECEF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#222733"/>
            <Setter Property="BorderBrush" Value="#2F3646"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E9ECEF"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Background" Value="#1B1F29"/>
            <Setter Property="BorderBrush" Value="#2F3646"/>
            <Setter Property="Foreground" Value="#E9ECEF"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="6"/>
        </Style>
    </Application.Resources>
</Application>
